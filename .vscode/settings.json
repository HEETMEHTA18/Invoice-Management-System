{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "figma.accessToken": "${env:FIGMA_ACCESS_TOKEN}",
  "figma.openFileInExternalEditor": false,
  "figma.showNotifications": true,
  "[figma]": {
    "editor.defaultFormatter": "figma.figma"
  }
}
